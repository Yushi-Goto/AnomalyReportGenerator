# Anomalib (Engine)
ANOMALIB_CKPT_PATH=./models/model.ckpt
ANOMALIB_MODEL_CLASS=Patchcore   # ckptを作ったモデル名に合わせる（例: Padim, Patchcore, EfficientAd など）
ANOMALIB_DEVICE=auto            # auto / cpu / cuda

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_INSTRUCTIONS=You are a helpful assistant for anomaly detection triage.
